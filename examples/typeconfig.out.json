{
  "type": "EHR",
  "validRelations": [
    "owner",
    "editor",
    "appender",
    "viewer"
  ],
  "relationRules": [
    {
      "affected": "appender",
      "give": "editor"
    },
    {
      "affected": "viewer",
      "give": "editor"
    }
  ],
  "permissions": [
    {
      "name": "can_read",
      "grantedBy": [
        "viewer",
        "editor",
        "owner"
      ]
    },
    {
      "name": "can_edit",
      "grantedBy": [
        "editor"
      ]
    },
    {
      "name": "can_delete",
      "grantedBy": [
        "owner"
      ]
    },
    {
      "name": "can_append",
      "grantedBy": [
        "appender",
        "editor"
      ]
    }
  ]
}